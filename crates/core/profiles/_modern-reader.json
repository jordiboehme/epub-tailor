{
  "description": "Shared base for a capable modern reader: repair, fit the images, rasterize the SVG - and none of the CrossPoint downgrades",
  "features": {
    "strip_fonts": false,
    "filter_css": false,
    "relocate_styles": false,
    "transcode_images": true,
    "rasterize_svg": true,
    "linearize_tables": false,
    "degrade_boxes": false,
    "bake_ordered_lists": false,
    "preserve_code_blocks": false,
    "normalize_footnotes": false,
    "relocate_anchors": false,
    "dedupe_ids": true,
    "unicode_hygiene": true,
    "chapter_split": false,
    "remap_colors": false
  },
  "options": {
    "jpeg_quality": 85
  }
}
