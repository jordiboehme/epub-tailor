{
  "name": "tolino-vision-color",
  "description": "tolino vision color, 7in Kaleido 3 (Kobo-based firmware)",
  "device": {
    "screen": { "width": 1264, "height": 1680, "ppi": 300 },
    "panel": "color",
    "images": {
      "max_source_px": [2000, 2000],
      "inline_max": [1264, 1680],
      "cover_max": [1264, 1680],
      "inline_budget_kb": 700,
      "cover_budget_kb": 1400
    }
  },
  "features": {
    "strip_fonts": false,
    "filter_css": false,
    "relocate_styles": false,
    "transcode_images": true,
    "rasterize_svg": true,
    "linearize_tables": false,
    "degrade_boxes": false,
    "bake_ordered_lists": false,
    "preserve_code_blocks": false,
    "normalize_footnotes": false,
    "relocate_anchors": false,
    "dedupe_ids": true,
    "unicode_hygiene": true,
    "chapter_split": true
  },
  "options": {
    "jpeg_quality": 85,
    "max_chapter_kb": 500
  },
  "output": { "appendix": "tolino-vision-color" }
}
